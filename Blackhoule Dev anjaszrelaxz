local function refreshPlayers(filter)
    for _, c in ipairs(PlayerListContainer:GetChildren()) do
        if c:IsA("TextButton") then c:Destroy() end
    end

    for _, p in ipairs(Players:GetPlayers()) do
        if not filter or filter == "" or p.Name:lower():find(filter:lower()) or p.DisplayName:lower():find(filter:lower()) then
            local btn = Instance.new("TextButton", PlayerListContainer)
            btn.Size = UDim2.new(1, 0, 0, 40)
            btn.BackgroundColor3 = Color3.fromRGB(35, 35, 48)
            btn.Text = "      " .. p.DisplayName .. " (@" .. p.Name .. ")"
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.TextSize = 12
            btn.Font = Enum.Font.GothamMedium
            btn.TextXAlignment = Enum.TextXAlignment.Left
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

            local success, thumb = pcall(function()
                return Players:GetUserThumbnailAsync(p.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size42x42)
            end)
            if success then
                local icon = Instance.new("ImageLabel", btn)
                icon.Size = UDim2.new(0, 30, 0, 30)
                icon.Position = UDim2.new(0, 5, 0.5, -15)
                icon.Image = thumb
                icon.BackgroundTransparency = 1
                Instance.new("UICorner", icon).CornerRadius = UDim.new(1, 0)
            end

            btn.MouseButton1Click:Connect(function()
                if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    selectedTargetPart = p.Character.HumanoidRootPart
                    SearchBox.Text = p.Name
                end
            end)
        end
    end
    PlayerListContainer.CanvasSize = UDim2.new(0, 0, 0, pLayout.AbsoluteContentSize.Y)
end

SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
    refreshPlayers(SearchBox.Text)
end)
