local function setupPlayer()
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

    local Folder = Workspace:FindFirstChild("BlackholeFolder") or Instance.new("Folder", Workspace)
    Folder.Name = "BlackholeFolder"

    local Part = Folder:FindFirstChild("CenterPart") or Instance.new("Part", Folder)
    Part.Name = "CenterPart"
    Part.Anchored = true
    Part.CanCollide = false
    Part.Transparency = 1

    local Attachment1 = Part:FindFirstChild("Attachment") or Instance.new("Attachment", Part)

    return humanoidRootPart, Attachment1
end

