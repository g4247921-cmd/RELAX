-- Network Handler
if not getgenv().Network then
    getgenv().Network = {
        BaseParts = {},
        Velocity = Vector3.new(14.46, 14.46, 14.46)
    }

    Network.RetainPart = function(part)
        if typeof(part) == "Instance" and part:IsA("BasePart") and part:IsDescendantOf(Workspace) then
            if not table.find(Network.BaseParts, part) then
                table.insert(Network.BaseParts, part)
                pcall(function()
                    part.CustomPhysicalProperties = PhysicalProperties.new(0, 0, 0, 0, 0)
                end)
                part.CanCollide = false
            end
        end
    end

    RunService.Heartbeat:Connect(function()
        pcall(function()
            sethiddenproperty(LocalPlayer, "SimulationRadius", math.huge)
        end)
        for _, part in pairs(Network.BaseParts) do
            if part and part:IsDescendantOf(Workspace) and not part.Anchored then
                part.Velocity = Network.Velocity
            end
        end
    end)
end

-- Core Blackhole ForcePart Engine
local function ForcePart(v)
    if not blackHoleActive then return end

    if v:IsA("BasePart") and not v.Anchored then
        if v.Name == "HumanoidRootPart" or v.Name == "Head" or v.Name == "Handle" then return end
        if v:IsDescendantOf(LocalPlayer.Character) then return end

        local model = v:FindFirstAncestorOfClass("Model")
        if model then
            if model:FindFirstChildOfClass("Humanoid") then
                return -- Ignore other players' characters / NPCs
            end
        end

        for _, x in ipairs(v:GetChildren()) do
            if x:IsA("BodyMover") or x:IsA("BodyVelocity") or x:IsA("BodyPosition") or x:IsA("BodyGyro") or x:IsA("RocketPropulsion") or x:IsA("AlignPosition") or x:IsA("Torque") then
                x:Destroy()
            end
        end

        v.CanCollide = false
        if getgenv().Network and getgenv().Network.RetainPart then
            getgenv().Network.RetainPart(v)
        end

        if not v:FindFirstChild("BlackholeTorque") then
            local Torque = Instance.new("Torque", v)
            Torque.Name = "BlackholeTorque"
            Torque.Torque = Vector3.new(1e6, 1e6, 1e6)

            local Attachment2 = Instance.new("Attachment", v)
            Attachment2.Name = "BlackholeAtt"
            Torque.Attachment0 = Attachment2

            local AlignPosition = Instance.new("AlignPosition", v)
            AlignPosition.Name = "BlackholeAlign"
            AlignPosition.MaxForce = math.huge
            AlignPosition.MaxVelocity = math.huge
            AlignPosition.Responsiveness = 500
            AlignPosition.Attachment0 = Attachment2
            AlignPosition.Attachment1 = Attachment1
        end
    end
end

local function toggleBlackHole()
    blackHoleActive = not blackHoleActive
    if blackHoleActive then
        for _, v in ipairs(Workspace:GetDescendants()) do
            ForcePart(v)
        end

        Workspace.DescendantAdded:Connect(function(v)
            if blackHoleActive then
                ForcePart(v)
            end
        end)

        spawn(function()
            while blackHoleActive and RunService.RenderStepped:Wait() do
                if rotateActive then
                    angle = angle + math.rad(angleSpeed)
                end
                local offsetX = math.cos(angle) * radius
                local offsetZ = math.sin(angle) * radius

                local targetRef = humanoidRootPart
                if selectedTargetPart and selectedTargetPart.Parent and selectedTargetPart.Parent:FindFirstChild("Humanoid") then
                    targetRef = selectedTargetPart
                    if followTarget and humanoidRootPart and humanoidRootPart.Parent then
                        humanoidRootPart.CFrame = CFrame.new(selectedTargetPart.Position + Vector3.new(0, 5, 0))
                    end
                end

                if Attachment1 and Attachment1.Parent then
                    Attachment1.WorldCFrame = targetRef.CFrame * CFrame.new(offsetX, orbitHeight, offsetZ)
                end
            end
        end)
    else
        if Attachment1 then
            Attachment1.WorldCFrame = CFrame.new(0, -10000, 0)
        end
        for _, part in ipairs(Workspace:GetDescendants()) do
            if part:IsA("BasePart") then
                if part:FindFirstChild("BlackholeAlign") then part.BlackholeAlign:Destroy() end
                if part:FindFirstChild("BlackholeTorque") then part.BlackholeTorque:Destroy() end
                if part:FindFirstChild("BlackholeAtt") then part.BlackholeAtt:Destroy() end
            end
        end
        table.clear(getgenv().Network.BaseParts)
    end
end

LocalPlayer.CharacterAdded:Connect(function()
